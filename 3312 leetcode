import java.util.Arrays;

public class Solution {
    public int[] gcdValues(int[] nums, long[] queries) {
        int maxVal = 0;
        for (int num : nums) {
            maxVal = Math.max(maxVal, num);
        }

        // Step 1: Count frequencies of each number
        int[] cnt = new int[maxVal + 1];
        for (int num : nums) {
            cnt[num]++;
        }

        // Step 2: Count how many elements are multiples of each i
        long[] gcdPairsCount = new long[maxVal + 1];
        for (int i = maxVal; i >= 1; i--) {
            long multiples = 0;
            for (int j = i; j <= maxVal; j += i) {
                multiples += cnt[j];
            }
            
            // Total pairs where both elements are multiples of i
            long totalPairs = multiples * (multiples - 1) / 2;
            
            // Step 3: Subtract pairs that have a strictly larger common divisor (multiples of i)
            for (int j = 2 * i; j <= maxVal; j += i) {
                totalPairs -= gcdPairsCount[j];
            }
            gcdPairsCount[i] = totalPairs;
        }

        // Step 4: Compute prefix sums of the number of pairs
        long[] prefixSums = new long[maxVal + 1];
        for (int i = 1; i <= maxVal; i++) {
            prefixSums[i] = prefixSums[i - 1] + gcdPairsCount[i];
        }

        // Step 5: Process each query using binary search
        int[] answer = new int[queries.length];
        for (int i = 0; i < queries.length; i++) {
            long query = queries[i];
            
            // Find the smallest index where prefixSums[idx] > query
            int low = 1, high = maxVal, ans = maxVal;
            while (low <= high) {
                int mid = low + (high - low) / 2;
                if (prefixSums[mid] > query) {
                    ans = mid;
                    high = mid - 1;
                } else {
                    low = mid + 1;
                }
            }
            answer[i] = ans;
        }

        return answer;
    }
}
