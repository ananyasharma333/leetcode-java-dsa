import java.util.*;

class Solution {
    public int countCompleteComponents(int n, int[][] edges) {
        // Step 1: Build the adjacency list
        List<List<Integer>> adj = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            adj.add(new ArrayList<>());
        }
        for (int[] edge : edges) {
            adj.get(edge[0]).add(edge[1]);
            adj.get(edge[1]).add(edge[0]);
        }

        boolean[] visited = new boolean[n];
        int completeComponentCount = 0;

        // Step 2: Traverse every component
        for (int i = 0; i < n; i++) {
            if (!visited[i]) {
                int[] counts = new int[2]; // counts[0] = vertex count, counts[1] = edge count
                dfs(i, adj, visited, counts);
                
                int V = counts[0];
                int E = counts[1];

                // In an undirected graph, each edge is traversed twice (once from each endpoint)
                // So the total edge count accumulated should equal V * (V - 1)
                if (E == V * (V - 1)) {
                    completeComponentCount++;
                }
            }
        }

        return completeComponentCount;
    }

    private void dfs(int u, List<List<Integer>> adj, boolean[] visited, int[] counts) {
        visited[u] = true;
        counts[0]++; // Increment vertex count
        counts[1] += adj.get(u).size(); // Add the number of neighbors (edges) connected to u

        for (int v : adj.get(u)) {
            if (!visited[v]) {
                dfs(v, adj, visited, counts);
            }
        }
    }
}
