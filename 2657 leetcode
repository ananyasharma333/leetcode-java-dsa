class Solution {
    public int[] findThePrefixCommonArray(int[] A, int[] B) {
        int n = A.length;
        int[] C = new int[n];
        // Since elements are from 1 to n, size n + 1 is perfect
        int[] counts = new int[n + 1]; 
        int commonCount = 0;

        for (int i = 0; i < n; i++) {
            // Process the element from array A
            counts[A[i]]++;
            if (counts[A[i]] == 2) {
                commonCount++;
            }

            // Process the element from array B
            counts[B[i]]++;
            if (counts[B[i]] == 2) {
                commonCount++;
            }

            // Store the running total for the current prefix
            C[i] = commonCount;
        }

        return C;
    }
}
