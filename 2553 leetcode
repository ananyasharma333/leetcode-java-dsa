import java.util.ArrayList;
import java.util.List;

class Solution {
    public int[] separateDigits(int[] nums) {
        List<Integer> digitList = new ArrayList<>();
        
        for (int num : nums) {
            // Temporary list to store digits of the current number
            List<Integer> temp = new ArrayList<>();
            
            while (num > 0) {
                temp.add(num % 10);
                num /= 10;
            }
            
            // Add digits to the main list in correct order (reverse of temp)
            for (int i = temp.size() - 1; i >= 0; i--) {
                digitList.add(temp.get(i));
            }
        }
        
        // Convert List back to primitive int array
        int[] result = new int[digitList.size()];
        for (int i = 0; i < digitList.size(); i++) {
            result[i] = digitList.get(i);
        }
        
        return result;
    }
}
