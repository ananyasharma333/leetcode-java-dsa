class Solution {
    public char[][] rotateTheBox(char[][] boxGrid) {
        int m = boxGrid.length;
        int n = boxGrid[0].length;

        // Step 1: Apply gravity to each row
        for (int i = 0; i < m; i++) {
            int lowestAvailable = n - 1; 
            
            // Iterate from right to left to let stones "fall" to the right
            for (int j = n - 1; j >= 0; j--) {
                if (boxGrid[i][j] == '*') {
                    // Obstacle resets the landing spot to just before it
                    lowestAvailable = j - 1;
                } else if (boxGrid[i][j] == '#') {
                    // Move stone to the lowest available spot
                    boxGrid[i][j] = '.';
                    boxGrid[i][lowestAvailable] = '#';
                    lowestAvailable--;
                }
            }
        }

        // Step 2: Rotate the box 90 degrees clockwise
        char[][] rotatedBox = new char[n][m];
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                // The new row is the old column
                // The new column is (total old rows - 1) - current old row
                rotatedBox[j][m - 1 - i] = boxGrid[i][j];
            }
        }

        return rotatedBox;
    }
}
