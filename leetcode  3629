import java.util.*;

class Solution {
    public int minJumps(int[] nums) {
        int n = nums.length;
        if (n <= 1) return 0;

        int maxVal = 0;
        for (int x : nums) maxVal = Math.max(maxVal, x);

        // 1. Precompute primes and factor mapping
        boolean[] isPrime = sieve(maxVal);
        Map<Integer, List<Integer>> primeToIndices = new HashMap<>();
        
        for (int i = 0; i < n; i++) {
            int val = nums[i];
            // Find all prime factors of nums[i]
            // Note: For teleportation, we need indices j where nums[j] % p == 0
            // So we map every number to its prime factors.
            List<Integer> factors = getPrimeFactors(val, isPrime);
            for (int p : factors) {
                primeToIndices.computeIfAbsent(p, k -> new ArrayList<>()).add(i);
            }
        }

        // 2. BFS
        Queue<Integer> queue = new LinkedList<>();
        boolean[] visitedIdx = new boolean[n];
        Set<Integer> usedPrimes = new HashSet<>();

        queue.offer(0);
        visitedIdx[0] = true;
        int jumps = 0;

        while (!queue.isEmpty()) {
            int size = queue.size();
            for (int i = 0; i < size; i++) {
                int curr = queue.poll();
                if (curr == n - 1) return jumps;

                // Option 1: Adjacent Steps
                int[] neighbors = {curr - 1, curr + 1};
                for (int next : neighbors) {
                    if (next >= 0 && next < n && !visitedIdx[next]) {
                        visitedIdx[next] = true;
                        queue.offer(next);
                    }
                }

                // Option 2: Prime Teleportation
                // Only if nums[curr] is prime
                if (isPrime[nums[curr]]) {
                    int p = nums[curr];
                    if (!usedPrimes.contains(p)) {
                        if (primeToIndices.containsKey(p)) {
                            for (int nextIdx : primeToIndices.get(p)) {
                                if (!visitedIdx[nextIdx]) {
                                    visitedIdx[nextIdx] = true;
                                    queue.offer(nextIdx);
                                }
                            }
                        }
                        usedPrimes.add(p); // Optimization: Never process this prime teleport again
                    }
                }
            }
            jumps++;
        }

        return -1;
    }

    private boolean[] sieve(int n) {
        boolean[] isP = new boolean[n + 1];
        Arrays.fill(isP, true);
        if (n >= 0) isP[0] = false;
        if (n >= 1) isP[1] = false;
        for (int p = 2; p * p <= n; p++) {
            if (isP[p]) {
                for (int i = p * p; i <= n; i += p) isP[i] = false;
            }
        }
        return isP;
    }

    private List<Integer> getPrimeFactors(int val, boolean[] isPrime) {
        List<Integer> factors = new ArrayList<>();
        if (val < 2) return factors;
        int d = val;
        for (int i = 2; i * i <= d; i++) {
            if (d % i == 0) {
                if (isPrime[i]) factors.add(i);
                while (d % i == 0) d /= i;
            }
        }
        if (d > 1 && isPrime[d]) factors.add(d);
        return factors;
    }
}
