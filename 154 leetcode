class Solution {
    public int findMin(int[] nums) {
        int left = 0;
        int right = nums.length - 1;

        while (left < right) {
            int mid = left + (right - left) / 2;

            if (nums[mid] > nums[right]) {
                // Minimum must be in the right part
                left = mid + 1;
            } else if (nums[mid] < nums[right]) {
                // Minimum is in the left part (including mid)
                right = mid;
            } else {
                // nums[mid] == nums[right]
                // Duplicate found: we can't be sure where the pivot is.
                // Shrink the search space by moving the right pointer inward.
                right--;
            }
        }

        // After the loop, left == right, pointing to the minimum element.
        return nums[left];
    }
}
