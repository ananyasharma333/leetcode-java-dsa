class Solution {
    public int maximumJumps(int[] nums, int target) {
        int n = nums.length;
        // dp[i] stores the max jumps to reach index i
        int[] dp = new int[n];
        
        // Initialize with -1 to represent unreachable indices
        Arrays.fill(dp, -1);
        
        // Base case: 0 jumps to stay at the starting index
        dp[0] = 0;

        for (int j = 1; j < n; j++) {
            for (int i = 0; i < j; i++) {
                // Check if index i is reachable AND if the jump condition is met
                if (dp[i] != -1 && Math.abs(nums[j] - nums[i]) <= target) {
                    dp[j] = Math.max(dp[j], dp[i] + 1);
                }
            }
        }

        return dp[n - 1];
    }
}
