class Solution {
    public int largestAltitude(int[] gain) {
        int maxAltitude = 0; // The biker starts at altitude 0
        int currentAltitude = 0; // Tracks the altitude at the current point
        
        // Loop through each net change in the gain array
        for (int i = 0; i < gain.length; i++) {
            currentAltitude += gain[i]; // Calculate the next point's altitude
            
            // If the current altitude is higher than our max, update maxAltitude
            if (currentAltitude > maxAltitude) {
                maxAltitude = currentAltitude;
            }
        }
        
        return maxAltitude;
    }
}
