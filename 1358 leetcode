class Solution {
    public int numberOfSubstrings(String s) {
        // Track the last seen positions of 'a', 'b', and 'c'
        int lastA = -1, lastB = -1, lastC = -1;
        int count = 0;
        
        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            
            // Update the last seen index for the current character
            if (ch == 'a') lastA = i;
            else if (ch == 'b') lastB = i;
            else if (ch == 'c') lastC = i;
            
            // If we have seen all three characters at least once
            if (lastA != -1 && lastB != -1 && lastC != -1) {
                // All indices from 0 up to the minimum of the three last seen positions
                // can form a valid starting point for a substring ending at 'i'.
                count += Math.min(lastA, Math.min(lastB, lastC)) + 1;
            }
        }
        
        return count;
    }
}
